---
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={`${project.title} 프로젝트 상세`} />
    <title>{project.title} | 최형민</title>
  </head>
  <body>
    <main class="shell">
      <nav class="topbar" aria-label="프로젝트 이동">
        <a class="back" href="/">← Home</a>
      </nav>

      <section class="hero">
        <p class="eyebrow">Project Detail</p>
        <h1>{project.title}</h1>
        <p class="subtitle">{project.subtitle}</p>
        <p class="summary">{project.summary}</p>
        <div class="hero-actions" aria-label="프로젝트 외부 링크">
          <a class="primary-action" href={project.github}>GitHub Repository</a>
          {project.demo && <a href={project.demo.url}>시연 영상</a>}
        </div>
        <div class="meta">
          <div>
            <span>Period</span>
            <strong>{project.period}</strong>
          </div>
          <div>
            <span>Team</span>
            <strong>{project.team}</strong>
          </div>
          <div>
            <span>Role</span>
            <strong>{project.role}</strong>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="section-title">
          <p class="eyebrow">Stack</p>
          <h2>Tech Stack</h2>
        </div>
        <ul class="tags">
          {project.stack.map((tag) => <li>{tag}</li>)}
        </ul>
      </section>

      {
        project.docs.length > 0 && (
          <section class="section">
            <div class="section-title">
              <p class="eyebrow">Documents</p>
              <h2>Reference Docs</h2>
            </div>
            <div class="doc-grid">
              {project.docs.map((doc) => (
                <a class="doc-card" href={doc.url}>
                  <span>Notion</span>
                  <strong>{doc.label}</strong>
                  <p>프로젝트를 진행하며 정리한 구현/학습 문서입니다.</p>
                </a>
              ))}
            </div>
          </section>
        )
      }

      <section class="section">
        <div class="section-title">
          <p class="eyebrow">Impact</p>
          <h2>Highlights</h2>
        </div>
        <div class="highlight-grid">
          {
            project.highlights.map((item) => (
              <article>
                <p>{item}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section">
        <div class="section-title">
          <p class="eyebrow">Implementation</p>
          <h2>Details</h2>
        </div>
        <div class="detail-list">
          {
            project.details.map((detail) => (
              <article>
                <h3>{detail.title}</h3>
                <p>{detail.body}</p>
              </article>
            ))
          }
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --ink: #17212b;
    --muted: #5f6f7c;
    --paper: #f5f7f4;
    --surface: #fffdfa;
    --line: #d8dfd9;
    --accent: #0f766e;
    --accent-dark: #155263;
    --accent-soft: #e2f2ee;
    --gold: #a16207;
    --shadow: 0 18px 44px rgba(23, 33, 43, 0.1);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-width: 320px;
    background:
      linear-gradient(120deg, rgba(15, 118, 110, 0.14), transparent 34rem),
      linear-gradient(230deg, rgba(161, 98, 7, 0.12), transparent 28rem),
      var(--paper);
    color: var(--ink);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .shell {
    width: min(1080px, calc(100% - 32px));
    margin: 0 auto;
    padding: 26px 0 72px;
  }

  .topbar {
    display: flex;
    min-height: 52px;
    align-items: center;
    justify-content: flex-start;
    gap: 16px;
    border-bottom: 1px solid var(--line);
    color: var(--muted);
    font-weight: 850;
  }

  .back {
    color: var(--ink);
  }

  .hero {
    padding: 54px 0 42px;
  }

  .eyebrow {
    margin: 0 0 14px;
    color: var(--accent);
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p,
  strong {
    overflow-wrap: anywhere;
  }

  h1 {
    max-width: 860px;
    margin: 0;
    font-size: clamp(3.4rem, 10vw, 7.4rem);
    line-height: 0.92;
    letter-spacing: 0;
  }

  h2 {
    margin: 0;
    font-size: 2rem;
    line-height: 1.08;
  }

  h3 {
    margin: 0;
    font-size: 1.08rem;
  }

  .subtitle {
    margin: 18px 0 0;
    color: var(--accent-dark);
    font-size: 1.35rem;
    font-weight: 850;
  }

  .summary {
    max-width: 820px;
    margin: 22px 0 0;
    color: var(--muted);
    font-size: 1.08rem;
    line-height: 1.75;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 30px;
  }

  .hero-actions a {
    display: inline-flex;
    min-height: 46px;
    align-items: center;
    justify-content: center;
    padding: 12px 16px;
    border: 1px solid var(--ink);
    border-radius: 8px;
    color: var(--ink);
    font-weight: 900;
  }

  .hero-actions .primary-action {
    background: var(--ink);
    color: #ffffff;
  }

  .meta {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin-top: 34px;
  }

  .meta div,
  .tags,
  .doc-card,
  .highlight-grid article,
  .detail-list article {
    border: 1px solid rgba(216, 223, 217, 0.98);
    border-radius: 8px;
    background: rgba(255, 253, 250, 0.9);
    box-shadow: var(--shadow);
  }

  .meta div {
    padding: 18px;
  }

  .meta span {
    display: block;
    color: var(--gold);
    font-size: 0.76rem;
    font-weight: 850;
    text-transform: uppercase;
  }

  .meta strong {
    display: block;
    margin-top: 8px;
    line-height: 1.4;
  }

  .section {
    display: grid;
    grid-template-columns: 230px minmax(0, 1fr);
    gap: 38px;
    padding: 52px 0;
    border-top: 1px solid var(--line);
  }

  .section-title {
    position: sticky;
    top: 24px;
    align-self: start;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 0;
    padding: 22px;
    list-style: none;
  }

  .tags li {
    padding: 8px 10px;
    border-radius: 8px;
    background: var(--accent-soft);
    color: var(--accent-dark);
    font-size: 0.88rem;
    font-weight: 800;
  }

  .highlight-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .doc-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .doc-card {
    padding: 22px;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease,
      border-color 160ms ease;
  }

  .doc-card:hover {
    border-color: rgba(15, 118, 110, 0.42);
    box-shadow: 0 24px 54px rgba(23, 33, 43, 0.14);
    transform: translateY(-3px);
  }

  .doc-card span {
    display: block;
    color: var(--gold);
    font-size: 0.76rem;
    font-weight: 850;
    text-transform: uppercase;
  }

  .doc-card strong {
    display: block;
    margin-top: 10px;
    color: var(--ink);
    font-size: 1.05rem;
  }

  .doc-card p {
    margin: 12px 0 0;
    color: var(--muted);
    line-height: 1.65;
  }

  .highlight-grid article,
  .detail-list article {
    padding: 22px;
  }

  .highlight-grid p,
  .detail-list p {
    margin: 0;
    color: var(--muted);
    line-height: 1.72;
  }

  .detail-list {
    display: grid;
    gap: 14px;
  }

  .detail-list h3 {
    margin-bottom: 12px;
  }

  @media (max-width: 860px) {
    .section,
    .meta,
    .doc-grid,
    .highlight-grid {
      grid-template-columns: 1fr;
    }

    .section-title {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .shell {
      width: min(100% - 24px, 640px);
      padding: 18px 0 48px;
    }

    .hero {
      padding-top: 36px;
    }

    .section {
      gap: 22px;
      padding: 38px 0;
    }

    h1 {
      font-size: clamp(3rem, 18vw, 5.2rem);
    }
  }
</style>
