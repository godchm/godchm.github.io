---
const profile = {
  name: '최형민',
  role: 'Frontend / Web Developer',
  location: 'Seoul, Korea',
  email: 'your-email@example.com',
  github: 'https://github.com/your-github-id',
  summary:
    '사용자가 빠르게 이해하고 편하게 사용할 수 있는 웹 경험을 만드는 개발자입니다. Astro 기반 정적 사이트, 반응형 UI, 접근성, 성능을 중요하게 생각합니다.',
};

const skills = [
  'Astro',
  'HTML',
  'CSS',
  'JavaScript',
  'TypeScript',
  'React',
  'GitHub Pages',
  'Responsive UI',
];

const projects = [
  {
    title: 'Personal Resume Site',
    period: '2026',
    description:
      'Astro와 GitHub Pages를 사용해 빠르고 관리하기 쉬운 개인 이력서 사이트를 구축했습니다.',
    points: ['정적 빌드 기반 배포 자동화', '모바일/데스크톱 반응형 레이아웃', '명확한 섹션 구조와 읽기 쉬운 타이포그래피'],
  },
  {
    title: 'Portfolio Project',
    period: '2025',
    description:
      '프로젝트 소개, 기술 스택, 문제 해결 과정을 한눈에 볼 수 있도록 정리한 포트폴리오 페이지입니다.',
    points: ['프로젝트별 성과 중심 구성', '재사용 가능한 스타일 시스템', 'SEO 기본 메타 정보 구성'],
  },
];

const experiences = [
  {
    company: 'Your Company',
    role: 'Web Developer',
    period: '2024 - Present',
    description:
      '웹 서비스의 UI 구현, 성능 개선, 배포 자동화 작업을 담당했습니다. 실제 내용으로 바꿔 넣으면 이력서 완성도가 확 올라갑니다.',
  },
  {
    company: 'Previous Team',
    role: 'Frontend Intern',
    period: '2023 - 2024',
    description:
      '디자인 시안을 바탕으로 반응형 페이지를 구현하고, 컴포넌트 단위의 유지보수성을 개선했습니다.',
  },
];
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={`${profile.name} 이력서 사이트`} />
    <title>{profile.name} | Resume</title>
  </head>
  <body>
    <main class="page-shell">
      <section class="hero" aria-labelledby="intro-title">
        <div class="hero-copy">
          <p class="eyebrow">Resume</p>
          <h1 id="intro-title">{profile.name}</h1>
          <p class="role">{profile.role}</p>
          <p class="summary">{profile.summary}</p>
          <div class="actions" aria-label="연락처">
            <a href={`mailto:${profile.email}`}>Email</a>
            <a href={profile.github}>GitHub</a>
          </div>
        </div>
        <aside class="quick-info" aria-label="기본 정보">
          <dl>
            <div>
              <dt>Location</dt>
              <dd>{profile.location}</dd>
            </div>
            <div>
              <dt>Email</dt>
              <dd>{profile.email}</dd>
            </div>
            <div>
              <dt>GitHub</dt>
              <dd>{profile.github.replace('https://', '')}</dd>
            </div>
          </dl>
        </aside>
      </section>

      <section class="section" aria-labelledby="skills-title">
        <div class="section-heading">
          <p class="eyebrow">Capabilities</p>
          <h2 id="skills-title">Skills</h2>
        </div>
        <ul class="skill-list">
          {skills.map((skill) => <li>{skill}</li>)}
        </ul>
      </section>

      <section class="section" aria-labelledby="experience-title">
        <div class="section-heading">
          <p class="eyebrow">Work</p>
          <h2 id="experience-title">Experience</h2>
        </div>
        <div class="timeline">
          {
            experiences.map((item) => (
              <article class="timeline-item">
                <p class="period">{item.period}</p>
                <h3>{item.role}</h3>
                <p class="company">{item.company}</p>
                <p>{item.description}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section" aria-labelledby="projects-title">
        <div class="section-heading">
          <p class="eyebrow">Selected</p>
          <h2 id="projects-title">Projects</h2>
        </div>
        <div class="project-grid">
          {
            projects.map((project) => (
              <article class="project-card">
                <div class="project-topline">
                  <h3>{project.title}</h3>
                  <span>{project.period}</span>
                </div>
                <p>{project.description}</p>
                <ul>
                  {project.points.map((point) => <li>{point}</li>)}
                </ul>
              </article>
            ))
          }
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --ink: #1f2933;
    --muted: #65717f;
    --line: #dce3ea;
    --paper: #fbfaf7;
    --panel: #ffffff;
    --accent: #0f766e;
    --accent-strong: #164e63;
    --soft: #edf7f5;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-width: 320px;
    background:
      linear-gradient(135deg, rgba(15, 118, 110, 0.12), transparent 32rem),
      var(--paper);
    color: var(--ink);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .page-shell {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
    padding: 56px 0;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 340px;
    gap: 32px;
    align-items: stretch;
    min-height: 62vh;
    padding: 48px 0 40px;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .eyebrow {
    margin: 0 0 12px;
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    overflow-wrap: anywhere;
  }

  h1 {
    margin: 0;
    font-size: clamp(3rem, 12vw, 7.4rem);
    line-height: 0.92;
    letter-spacing: 0;
  }

  h2 {
    margin: 0;
    font-size: 2rem;
    letter-spacing: 0;
  }

  h3 {
    margin: 0;
    font-size: 1.08rem;
    letter-spacing: 0;
  }

  .role {
    margin: 20px 0 0;
    color: var(--accent-strong);
    font-size: 1.35rem;
    font-weight: 700;
  }

  .summary {
    max-width: 680px;
    margin: 24px 0 0;
    color: var(--muted);
    font-size: 1.08rem;
    line-height: 1.75;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 32px;
  }

  .actions a {
    min-height: 44px;
    padding: 12px 18px;
    border: 1px solid var(--ink);
    border-radius: 8px;
    background: var(--ink);
    color: white;
    font-weight: 750;
  }

  .actions a + a {
    background: transparent;
    color: var(--ink);
  }

  .quick-info,
  .project-card,
  .timeline-item {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.84);
    box-shadow: 0 18px 50px rgba(31, 41, 51, 0.08);
  }

  .quick-info {
    align-self: center;
    padding: 26px;
  }

  dl {
    display: grid;
    gap: 20px;
    margin: 0;
  }

  dt {
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  dd {
    margin: 6px 0 0;
    font-weight: 700;
  }

  .section {
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr);
    gap: 40px;
    padding: 48px 0;
    border-top: 1px solid var(--line);
  }

  .skill-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-content: start;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .skill-list li {
    padding: 10px 13px;
    border: 1px solid rgba(15, 118, 110, 0.22);
    border-radius: 8px;
    background: var(--soft);
    color: var(--accent-strong);
    font-weight: 750;
  }

  .timeline,
  .project-grid {
    display: grid;
    gap: 16px;
  }

  .timeline-item,
  .project-card {
    padding: 22px;
  }

  .timeline-item p,
  .project-card p,
  .project-card li {
    color: var(--muted);
    line-height: 1.65;
  }

  .period,
  .company,
  .project-topline span {
    color: var(--accent);
    font-size: 0.92rem;
    font-weight: 800;
  }

  .company {
    margin: 8px 0 12px;
  }

  .project-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .project-topline {
    display: flex;
    gap: 12px;
    align-items: start;
    justify-content: space-between;
  }

  .project-card ul {
    margin: 16px 0 0;
    padding-left: 20px;
  }

  @media (max-width: 780px) {
    .page-shell {
      width: min(100% - 24px, 680px);
      padding: 24px 0 40px;
    }

    .hero,
    .section,
    .project-grid {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
      padding-top: 32px;
    }

    .section {
      gap: 20px;
      padding: 36px 0;
    }
  }
</style>
