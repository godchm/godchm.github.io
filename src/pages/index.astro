---
import { projects } from '../data/projects';

const profile = {
  name: '최형민',
  role: '서버/백엔드 개발자',
  location: 'Seoul, Korea',
  email: 'stc05051@naver.com',
  github: 'https://github.com/godchm',
  headline: '문제를 구조로 해결하고, 운영까지 책임지는 백엔드 개발자',
  summary:
    'KDT 실시간 커머스 플랫폼 개발자 양성과정을 수료했습니다. Java/Spring 기반 백엔드 프로젝트에서 동시성 제어, 검색 최적화, RAG 추천, 모니터링, 무중단 배포를 경험했습니다.',
};

const highlights = [
  { label: 'Track', value: 'Backend Bootcamp' },
  { label: 'Core', value: 'Java / Spring' },
  { label: 'Projects', value: '4 Backend Builds' },
];

const skillGroups = [
  {
    title: 'Backend',
    items: ['Java', 'Spring Boot', 'Spring Security', 'Spring Data JPA', 'QueryDSL', 'JWT'],
  },
  {
    title: 'Data / Infra',
    items: ['MySQL', 'PostgreSQL', 'Redis', 'Kafka', 'Docker', 'AWS', 'GitHub Actions'],
  },
  {
    title: 'Ops / AI',
    items: ['Prometheus', 'Grafana', 'Loki', 'n8n', 'Spring AI', 'OpenAI API', 'RAG'],
  },
];

const education = {
  school: '팀 스파르타',
  course: 'KDT 실시간 커머스 플랫폼 개발자 양성과정 수료',
  period: '2025.12 - 2026.06',
};
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={`${profile.name} 백엔드 개발자 이력서`} />
    <title>{profile.name} | Backend Resume</title>
  </head>
  <body>
    <main class="shell">
      <nav class="topbar" aria-label="페이지 내 이동">
        <a class="brand" href="/">CHM</a>
        <div>
          <a href="#skills">Skills</a>
          <a href="#projects">Projects</a>
          <a href="#education">Education</a>
        </div>
      </nav>

      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-copy">
          <p class="eyebrow">Backend Developer Resume</p>
          <h1 id="hero-title">{profile.name}</h1>
          <p class="role">{profile.role}</p>
          <p class="headline">{profile.headline}</p>
          <p class="summary">{profile.summary}</p>

          <div class="actions" aria-label="연락 링크">
            <a class="primary" href="#projects">프로젝트 보기</a>
            <a href={`mailto:${profile.email}`}>Email</a>
            <a href={profile.github}>GitHub</a>
          </div>
        </div>

        <aside class="profile-panel" aria-label="프로필 요약">
          <div class="avatar" aria-hidden="true">BE</div>
          <dl>
            <div>
              <dt>Location</dt>
              <dd>{profile.location}</dd>
            </div>
            <div>
              <dt>Email</dt>
              <dd>{profile.email}</dd>
            </div>
            <div>
              <dt>GitHub</dt>
              <dd>{profile.github.replace('https://', '')}</dd>
            </div>
          </dl>
        </aside>
      </section>

      <section class="metrics" aria-label="핵심 정보">
        {
          highlights.map((item) => (
            <div class="metric">
              <span>{item.label}</span>
              <strong>{item.value}</strong>
            </div>
          ))
        }
      </section>

      <section class="section" id="skills" aria-labelledby="skills-title">
        <div class="section-title">
          <p class="eyebrow">Capabilities</p>
          <h2 id="skills-title">Skills</h2>
        </div>
        <div class="skill-grid">
          {
            skillGroups.map((group) => (
              <article class="skill-card">
                <h3>{group.title}</h3>
                <ul>
                  {group.items.map((skill) => <li>{skill}</li>)}
                </ul>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section" id="projects" aria-labelledby="projects-title">
        <div class="section-title">
          <p class="eyebrow">Selected Work</p>
          <h2 id="projects-title">Projects</h2>
          <p>카드를 누르면 프로젝트별 구현 내용과 기술적 의사결정을 자세히 볼 수 있습니다.</p>
        </div>
        <div class="project-grid">
          {
            projects.map((project) => (
              <a class="project-card" href={`/projects/${project.slug}/`}>
                <div class="project-top">
                  <span>{project.period}</span>
                  <strong>{project.team}</strong>
                </div>
                <h3>{project.title}</h3>
                <p class="subtitle">{project.subtitle}</p>
                <p>{project.summary}</p>
                <ul class="tags" aria-label={`${project.title} 기술 스택`}>
                  {project.stack.slice(0, 6).map((tag) => <li>{tag}</li>)}
                </ul>
                <span class="read-more">상세 보기</span>
              </a>
            ))
          }
        </div>
      </section>

      <section class="section" id="education" aria-labelledby="education-title">
        <div class="section-title">
          <p class="eyebrow">Education</p>
          <h2 id="education-title">Education</h2>
        </div>
        <article class="education-card">
          <span>{education.period}</span>
          <h3>{education.school}</h3>
          <p>{education.course}</p>
          <p>
            백엔드 개발 과정을 통해 Java/Spring 기반 서비스 개발, 팀 프로젝트 협업, 배포 자동화,
            모니터링, 동시성 제어와 같은 실무형 주제를 프로젝트로 학습했습니다.
          </p>
        </article>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --ink: #17212b;
    --muted: #5f6f7c;
    --paper: #f5f7f4;
    --surface: #fffdfa;
    --line: #d8dfd9;
    --accent: #0f766e;
    --accent-dark: #155263;
    --accent-soft: #e2f2ee;
    --gold: #a16207;
    --shadow: 0 18px 44px rgba(23, 33, 43, 0.1);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-width: 320px;
    background:
      linear-gradient(120deg, rgba(15, 118, 110, 0.14), transparent 34rem),
      linear-gradient(230deg, rgba(161, 98, 7, 0.12), transparent 28rem),
      var(--paper);
    color: var(--ink);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .shell {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
    padding: 26px 0 72px;
  }

  .topbar {
    display: flex;
    min-height: 52px;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    border-bottom: 1px solid var(--line);
  }

  .brand {
    display: grid;
    width: 38px;
    height: 38px;
    place-items: center;
    border-radius: 50%;
    background: var(--ink);
    color: #fff;
    font-weight: 900;
  }

  .topbar div {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    color: var(--muted);
    font-size: 0.94rem;
    font-weight: 800;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 340px;
    gap: 32px;
    align-items: stretch;
    min-height: 66vh;
    padding: 50px 0 30px;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .eyebrow {
    margin: 0 0 14px;
    color: var(--accent);
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p,
  dd {
    overflow-wrap: anywhere;
  }

  h1 {
    max-width: 760px;
    margin: 0;
    font-size: clamp(4rem, 13vw, 8.2rem);
    line-height: 0.9;
    letter-spacing: 0;
  }

  h2 {
    margin: 0;
    font-size: 2rem;
    line-height: 1.08;
    letter-spacing: 0;
  }

  h3 {
    margin: 0;
    font-size: 1.08rem;
    letter-spacing: 0;
  }

  .role {
    margin: 24px 0 0;
    color: var(--accent-dark);
    font-size: 1.35rem;
    font-weight: 800;
  }

  .headline {
    max-width: 720px;
    margin: 18px 0 0;
    font-size: clamp(1.45rem, 3vw, 2.35rem);
    line-height: 1.22;
    font-weight: 850;
  }

  .summary,
  .section-title p,
  .project-card p,
  .education-card p {
    color: var(--muted);
    line-height: 1.72;
  }

  .summary {
    max-width: 700px;
    margin: 22px 0 0;
    font-size: 1.06rem;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 32px;
  }

  .actions a {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    padding: 12px 18px;
    border: 1px solid var(--ink);
    border-radius: 8px;
    color: var(--ink);
    font-weight: 800;
  }

  .actions .primary {
    background: var(--ink);
    color: #ffffff;
  }

  .profile-panel,
  .metric,
  .skill-card,
  .project-card,
  .education-card {
    border: 1px solid rgba(216, 223, 217, 0.98);
    border-radius: 8px;
    background: rgba(255, 253, 250, 0.9);
    box-shadow: var(--shadow);
  }

  .profile-panel {
    align-self: center;
    padding: 28px;
  }

  .avatar {
    display: grid;
    width: 86px;
    height: 86px;
    place-items: center;
    margin-bottom: 28px;
    border-radius: 50%;
    background: var(--ink);
    color: #ffffff;
    font-size: 1rem;
    font-weight: 900;
  }

  dl {
    display: grid;
    gap: 20px;
    margin: 0;
  }

  dt {
    color: var(--muted);
    font-size: 0.76rem;
    font-weight: 850;
    text-transform: uppercase;
  }

  dd {
    margin: 6px 0 0;
    color: var(--ink);
    font-weight: 800;
  }

  .metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    padding: 18px 0 42px;
  }

  .metric {
    padding: 18px;
  }

  .metric span,
  .project-top span,
  .education-card span {
    display: block;
    color: var(--gold);
    font-size: 0.78rem;
    font-weight: 850;
    text-transform: uppercase;
  }

  .metric strong {
    display: block;
    margin-top: 8px;
    color: var(--accent-dark);
    font-size: 1.15rem;
  }

  .section {
    display: grid;
    grid-template-columns: 230px minmax(0, 1fr);
    gap: 38px;
    padding: 52px 0;
    border-top: 1px solid var(--line);
  }

  .section-title {
    position: sticky;
    top: 24px;
    align-self: start;
  }

  .skill-grid,
  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .skill-card,
  .project-card,
  .education-card {
    padding: 22px;
  }

  .skill-card ul,
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 18px 0 0;
    padding: 0;
    list-style: none;
  }

  .skill-card li,
  .tags li {
    padding: 8px 10px;
    border-radius: 8px;
    background: var(--accent-soft);
    color: var(--accent-dark);
    font-size: 0.88rem;
    font-weight: 800;
  }

  .project-card {
    display: flex;
    min-height: 360px;
    flex-direction: column;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease,
      border-color 160ms ease;
  }

  .project-card:hover {
    border-color: rgba(15, 118, 110, 0.42);
    box-shadow: 0 24px 54px rgba(23, 33, 43, 0.14);
    transform: translateY(-3px);
  }

  .project-top {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 20px;
  }

  .project-top strong {
    color: var(--muted);
    font-size: 0.84rem;
  }

  .subtitle {
    margin: 8px 0 0;
    color: var(--accent-dark);
    font-weight: 800;
  }

  .read-more {
    margin-top: auto;
    padding-top: 24px;
    color: var(--accent);
    font-weight: 900;
  }

  .education-card h3 {
    margin-top: 12px;
  }

  @media (max-width: 900px) {
    .hero,
    .section,
    .skill-grid,
    .project-grid {
      grid-template-columns: 1fr;
    }

    .section-title {
      position: static;
    }

    .project-card {
      min-height: auto;
    }
  }

  @media (max-width: 640px) {
    .shell {
      width: min(100% - 24px, 640px);
      padding: 18px 0 48px;
    }

    .topbar {
      align-items: flex-start;
      flex-direction: column;
      padding-bottom: 14px;
    }

    .hero {
      min-height: auto;
      padding-top: 34px;
    }

    .metrics {
      grid-template-columns: 1fr;
      padding-bottom: 30px;
    }

    .section {
      gap: 22px;
      padding: 38px 0;
    }

    h1 {
      font-size: clamp(3.4rem, 22vw, 5.4rem);
    }
  }
</style>
